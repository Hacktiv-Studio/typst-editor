{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "preview-popup"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-hide",
    "core:window:allow-show"
  ]
}
